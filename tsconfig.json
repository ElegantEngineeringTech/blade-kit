{
    "extends": ["@vue/tsconfig/tsconfig.dom.json", "@vue/tsconfig/tsconfig.lib.json"],
    "compilerOptions": {
        "lib": ["ES2023", "DOM", "DOM.Iterable"],
        "paths": {
            "@/*": ["./resources/ts/*"],
            "@workbench/*": ["./workbench/resources/js/*"]
        }
    },
    "include": [
        "workbench/resources/js/**/*.ts",
        "workbench/resources/js/**/*.vue",
        "resources/ts/**/*.ts",
        "resources/ts/**/*.d.ts",
        "resources/ts/**/*.tsx",
        "resources/ts/**/*.vue"
    ]
}
